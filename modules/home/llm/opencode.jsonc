{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "default_agent": "plan",
  // When looking to add a provider using the env, 
  // check the toml config in https://github.com/anomalyco/models.dev/tree/dev/providers for the specific env var used
  // Provider configuration
  // Docs: https://opencode.ai/config.json
  // Models reference: https://models.dev/api.json and use OpenRouter as provider (search for Kimi K2.5)
  "provider": {
    "CrofAI": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "CrofAI",
      "options": {
        "baseURL": "https://crof.ai/v1",
        "apiKey": "{env:CROFAI_API_KEY}"
      },
      "models": {
        "mimo-v2.5-pro-precision": {
          "name": "CrofAI: mimo-v2.5-pro (precision)",
          "limit": {
            "context": 1000000,
            "output": 131072
          }
        },
        "deepseek-v4-pro-precision": {
          "name": "CrofAI: deepseek-v4-pro (precision)",
          "limit": {
            "context": 1000000,
            "output": 131072
          }
        },
        "kimi-k2.6-precision": {
          "name": "CrofAI: kimi-k2.6 (precision)",
          "limit": {
            "context": 262144,
            "output": 262144
          }
        },
        "glm-5.1-precision": {
          "name": "CrofAI: glm-5.1-precision",
          "limit": {
            "context": 202752,
            "output": 202752
          }
        },
      }
    }
  },
  // Use with: `use the <tool_name> tool`
  // Debug: opencode mcp list
  // Note: keep some disabled if not used as they add multiple 1000s tokens to context for the tool instructions
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
    },
    "godoc": {
      "type": "local",
      "command": [
        "go",
        "run",
        "github.com/mrjoshuak/godoc-mcp@latest"
      ],
      "enabled": true,
      "environment": {
        "CGO_ENABLED": "0",
      },
    },
    "nixos": {
      "type": "local",
      "command": [
        "nix",
        "run",
        "github:utensils/mcp-nixos",
        "--"
      ],
      "enabled": true,
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,web_fetch_exa,web_search_advanced_exa",
      "enabled": true,
      "headers": {
        "x-api-key": "{env:EXA_API_KEY}"
      }
    },
    "pdf-reader": {
      "type": "local",
      "command": [
        "bunx",
        "@sylphx/pdf-reader-mcp"
      ],
      "enabled": true,
    },
    "docs-mcp-server": {
      "type": "remote",
      "url": "http://localhost:6280/sse",
      "enabled": true,
    },
    //
    // Not needed most of the time and add a lot to context
    //
    "websets": {
      "type": "remote",
      "url": "https://websetsmcp.exa.ai",
      "enabled": false, // Adds 12k tokens to context
      "headers": {
        "x-api-key": "{env:EXA_API_KEY}"
      }
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "bunx",
        "chrome-devtools-mcp@latest",
        "--executable-path",
        "@chromium@"
      ],
      "enabled": false,
      "environment": {
        "CHROME_DEVTOOLS_MCP_NO_USAGE_STATISTICS": "true",
      }
    },
    /*
    // Waiting for https://github.com/langflow-ai/openrag/issues/981#issuecomment-3947831540
    "openrag": {
      "type": "local",
      "command": ["uvx", "openrag-mcp"],
      "enabled": true,
      "environment": {
        "OPENRAG_URL": "https://your-openrag-instance.com",
        "OPENRAG_API_KEY": "orag_your_api_key_here",
      },
    },
    */
  },
  "permission": {
    "external_directory": {
      "/tmp/**": "allow",
      "~/repos/**": "allow",
      "~/go/**": "allow"
    },
    "edit": {
      "/tmp/**": "allow",
      "~/repos/**": "ask",
      "~/go/**": "deny"
    }
  },
  "tool_output": {
    "max_lines": 50000,
    "max_bytes": 10485760
  },
  "plugin": [
    "cc-safety-net",
  ],
}