{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,

  // When looking to add a provider using the env, 
  // check the toml config in https://github.com/anomalyco/models.dev/tree/dev/providers for the specific env var used

  // Provider configuration
  // Docs: https://opencode.ai/config.json
  // Models reference: https://models.dev/api.json and use OpenRouter as provider (search for Kimi K2.5)
  /*
  "provider": {
    "byteplus": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "byteplus",
      "options": {
        "baseURL": "https://ark.ap-southeast.bytepluses.com/api/coding/v3",
        "apiKey": "{env:BYTEPLUS_API_KEY}",
      },
      "models": {
        "kimi-k2.5": {
          "name": "Kimi K2.5",
          "reasoning": true,
          "tool_call": true,
          "temperature": true,
          "interleaved": true,
          "limit": {
            "context": 262144,
            "output": 65000,
          },
          "modalities": {
            "input": ["text", "image", "video"],
            "output": ["text"],
          },
          "options": {
            "temperature": 1.0,
            "top_p": 0.95,
          },
        },
      },
    },
  },
  */

  // Use with: `use the <tool_name> tool`
  // Debug: opencode mcp list
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
    },
    "godoc": {
      "type": "local",
      "command": ["go", "run", "github.com/mrjoshuak/godoc-mcp@latest"],
      "enabled": true,
      "environment": {
        "CGO_ENABLED": "0",
      },
    },
    "nixos": {
      "type": "local",
      "command": ["nix", "run", "github:utensils/mcp-nixos", "--"],
      "enabled": true,
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,web_fetch_exa,web_search_advanced_exa",
      "enabled": true,
      "headers": {
        "x-api-key": "{env:EXA_API_KEY}"
      }
    },
    "websets": {
      "type": "remote",
      "url": "https://websetsmcp.exa.ai",
      "enabled": true,
      "headers": {
        "x-api-key": "{env:EXA_API_KEY}"
      }
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["bunx", "chrome-devtools-mcp@latest", "--executable-path", "@chromium@"],
      "environment": {
        "CHROME_DEVTOOLS_MCP_NO_USAGE_STATISTICS": "true",
      }
    },
    "pdf-reader": { 
      "type": "local",
      "command": ["bunx", "@sylphx/pdf-reader-mcp"],
      "enabled": true,
    },
    /*
    // Waiting for https://github.com/langflow-ai/openrag/issues/981#issuecomment-3947831540
    "openrag": {
      "type": "local",
      "command": ["uvx", "openrag-mcp"],
      "enabled": true,
      "environment": {
        "OPENRAG_URL": "https://your-openrag-instance.com",
        "OPENRAG_API_KEY": "orag_your_api_key_here",
      },
    },
    */
  },

  "permission": {
    "external_directory": {
      "/tmp/**": "allow"
    },
    "edit": {
      "/tmp/**": "allow"
    }
  },

  "plugin": ["cc-safety-net"],
}
