{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json",
  "packages": [
    "go-task@latest",
    "pre-commit@latest",
    "nixfmt-tree@latest",
    "deadnix@latest",
    "statix@latest",
    "python313@latest",
    "python313Packages.tabulate@latest",
    "python313Packages.matplotlib@latest",
    "mermaid-cli@latest",
    "hashrat@latest"
  ],
  "env": {
    "DEVBOX_NO_PROMPT": "true"
  },
  "shell": {
    "init_hook": [
      "pre-commit autoupdate",
      "pre-commit install",
      ". $VENV_DIR/bin/activate"
    ],
    "scripts": {
      "test": [
        "echo \"Error: no test specified\" && exit 1"
      ]
    }
  }
}
